{
  "name": "copperhead",
  "version": "0.6.0",
  "description": "Cursor for circuit boards: an AI agent that designs, documents, and validates real PCBs on KiCad repositories",
  "license": "Apache-2.0",
  "author": "Animesh Chouhan <animeshchouhan@outlook.com>",
  "homepage": "https://copperhead.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chouhanindustries/copperhead.git"
  },
  "bugs": {
    "url": "https://github.com/chouhanindustries/copperhead/issues"
  },
  "keywords": [
    "kicad",
    "pcb",
    "eda",
    "hardware",
    "electronics",
    "schematic",
    "erc",
    "drc",
    "ai-agent",
    "llm",
    "cli"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "copperhead": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run typecheck && npm run build",
    "dev": "tsx src/cli.ts",
    "demo:simple": "bash scripts/demo-simple.sh",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules/**\" \"#**/node_modules/**\" \"#dist/**\" \"#**/dist/**\" \"#docs/.astro/**\" \"#demo-runs/**\" \"#.copperhead/runs/**\" \"#_site/**\"",
    "lint:readme": "tsx scripts/check-readme-consistency.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:preview": "npm --prefix docs run preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "openai": "^4.87.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.217",
    "@maximem/synap-js-sdk": "^0.3.0"
  },
  "overrides": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@openai/codex-sdk": "^0.144.6",
    "@types/node": "^22.13.10",
    "markdownlint-cli2": "0.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "@openai/codex-sdk": "^0.144.6"
  },
  "peerDependenciesMeta": {
    "@openai/codex-sdk": {
      "optional": true
    }
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true
  }
}
